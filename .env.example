# Retrieval model. Default runs out of the box.
# Newer SOTA option: vidore/colqwen2.5-v0.2 (see embedder.py note).
COLPALI_MODEL=vidore/colqwen2-v1.0
DEVICE=auto

QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=
COLLECTION_NAME=apertura_pages

PDF_DPI=150
EMBED_BATCH_SIZE=4

# Windows only — path to poppler's bin folder (use forward slashes), e.g.:
# POPPLER_PATH=C:/poppler/poppler-24.08.0/Library/bin

# For the answerer (added in milestone 2)
# ANTHROPIC_API_KEY=
